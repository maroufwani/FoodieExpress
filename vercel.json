{
  "version": 2,
  "framework": null,
  "outputDirectory": "public",
  "buildCommand": "npm ci && npm run build",
  "installCommand": "npm install",
  "functions": {
    "api/index.php": {
      "runtime": "vercel-php@0.7.3"
    }
  },
  "routes": [
    {
      "src": ".*\\.php$",
      "dest": "/api/index.php"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ]
}
